# Copia questo file in .env e personalizza i valori
# Genera un nuovo CLUSTER_ID (KRaft) con:
#   docker run --rm confluentinc/cp-kafka:7.6.1 kafka-storage random-uuid

CLUSTER_ID=<genera-con-comando-sopra>
PRODUCER_DELAY_MS=500
ES_HEAP_SIZE=512m
MONGO_INITDB_DATABASE=sensor_data

# Webhook alert per eventi fire transition (opzionale — lascia vuoto per disabilitare)
# Ottieni un URL gratuito su https://webhook.site
ALERT_WEBHOOK_URL=
